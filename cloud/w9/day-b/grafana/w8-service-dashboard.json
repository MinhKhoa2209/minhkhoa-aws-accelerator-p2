{
  "title": "W8 Announcement Service",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Request Rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_total{service_name=\"announcement-app\"}[5m]))",
          "legendFormat": "rps"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error Rate",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_total{service_name=\"announcement-app\",status_code!~\"2..\"}[5m])) / sum(rate(http_server_requests_total{service_name=\"announcement-app\"}[5m]))",
          "legendFormat": "error ratio"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latency p95",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_request_duration_seconds_bucket{service_name=\"announcement-app\"}[5m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Availability SLI",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_total{service_name=\"announcement-app\",status_code=~\"2..\"}[30m])) / sum(rate(http_server_requests_total{service_name=\"announcement-app\"}[30m]))",
          "legendFormat": "availability"
        }
      ]
    }
  ]
}
